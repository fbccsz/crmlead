# Modo de desenvolvimento: usar mock local ou backend real
VITE_USE_MOCK_API=true

# URL base da API backend (quando VITE_USE_MOCK_API=false)
VITE_API_BASE_URL=http://localhost:8000/api

# Endpoint de health-check relativizado a VITE_API_BASE_URL
VITE_API_HEALTH_PATH=/health

# Configuracoes de resiliencia HTTP (em ms para timeout, em minutos para TTL)
VITE_HTTP_TIMEOUT_MS=8000
VITE_HTTP_RETRY_COUNT=1
VITE_SESSION_TTL_MINUTES=480
